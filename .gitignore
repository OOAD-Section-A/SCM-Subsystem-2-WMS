# ─── Compiled Output ─────────────────────────────────────────────────────────
# Maven places all compiled .class files and build artifacts here.
# This directory is regenerated by 'mvn compile' and must never be committed.
target/

# Stray .class files compiled outside Maven (e.g., direct javac usage)
*.class

# ─── Database Credentials ────────────────────────────────────────────────────
# Contains real JDBC credentials. NEVER commit this file.
lib/database.properties

# ─── External JARs ───────────────────────────────────────────────────────────
# Large binary files managed locally. Teammates get them from the shared drive
# or the respective subsystem teams directly.
# Exception: small, essential JARs (exception handler, GUI viewer) ARE committed.
lib/packing-subsystem-1.0-SNAPSHOT-all.jar
lib/database-module-1.0.0-SNAPSHOT-standalone.jar

# ─── Local Utility Files ─────────────────────────────────────────────────────
# Generated locally for developer convenience. Not part of the project source.
structure.txt
sources.txt

# ─── IDE and OS Files ────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db